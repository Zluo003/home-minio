MINIO_ROOT_USER=change-me-admin
MINIO_ROOT_PASSWORD=change-me-long-password
HOME_MINIO_BIND_ADDRESS=127.0.0.1
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
MINIO_DATA_DIR=./data
MINIO_BUCKET=waule-media
MINIO_INTERNAL_ENDPOINT=http://minio:9000
MINIO_WAULE_ACCESS_KEY=waule-newwaule
MINIO_WAULE_SECRET_KEY=change-me-minio-secret
HOME_MINIO_WEB_API_PORT=19090
HOME_MINIO_WEB_PORT=19091
HOME_MINIO_WEB_TOKEN=change-me-web-console-token
HOME_MINIO_STATE_DB=/data/state/home-minio.sqlite
HOME_MINIO_CONFIG_ENCRYPTION_KEY=
HOME_MINIO_CONFIG_ENCRYPTION_KEY_FILE=/run/secrets/home_minio_config_encryption_key
HOME_MINIO_CONFIG_ENCRYPTION_KEY_HOST_FILE=/dev/null
HOME_MINIO_TRANSFER_WORK_DIR=/data/transfer-work
HOME_MINIO_PUBLIC_ENDPOINT=http://100.x.y.z:19000
HOME_MINIO_CONSOLE_PUBLIC_URL=http://100.x.y.z:19001
NEWWAULE_API_BASE_URL=https://api.example.com
NEWWAULE_CACHE_UPLOAD_BASE_URL=
NEWWAULE_HOME_MINIO_TOKEN=change-me-web-console-token
CACHE_PUSH_CONCURRENCY=4
MEDIA_PULL_MANIFEST_PATH=./backup/newwaule-media-manifest.jsonl
MEDIA_PULL_WORK_DIR=./backup/pull
MEDIA_PULL_CONCURRENCY=4
OSS_FILE_CONCURRENCY=8
OSS_MULTIPART_CONCURRENCY=4
OSS_MAX_HTTP_CONCURRENCY=16
OSS_MULTIPART_THRESHOLD_BYTES=67108864
OSS_PART_SIZE_BYTES=16777216

# Baidu Netdisk backup. BaiduPCS-Go is recommended for SVIP accounts.
BAIDUPAN_BACKUP_ENABLED=false
BAIDUPAN_TOOL=baidupcs
BAIDUPAN_REMOTE_DIR=/NewWaule/home-minio
BAIDUPAN_WORK_DIR=./backup
BAIDUPAN_CRON_SCHEDULE=35 3 * * *
BYPY_BIN=bypy
BAIDUPCS_BIN=BaiduPCS-Go
BAIDUPCS_CONFIG_DIR=/root/.config/BaiduPCS-Go
BAIDUPCS_MAX_PARALLEL=16
BAIDUPCS_UPLOAD_NORAPID=true
