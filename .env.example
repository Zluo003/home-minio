MINIO_ROOT_USER=change-me-admin
MINIO_ROOT_PASSWORD=change-me-long-password
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
MINIO_DATA_DIR=./data
MINIO_BUCKET=waule-media
MINIO_WAULE_ACCESS_KEY=waule-newwaule
MINIO_WAULE_SECRET_KEY=change-me-minio-secret
HOME_MINIO_WEB_API_PORT=19090
HOME_MINIO_WEB_PORT=19091
HOME_MINIO_WEB_TOKEN=change-me-web-console-token

# Baidu Netdisk backup. BaiduPCS-Go is recommended for SVIP accounts.
BAIDUPAN_BACKUP_ENABLED=false
BAIDUPAN_TOOL=baidupcs
BAIDUPAN_REMOTE_DIR=/NewWaule/home-minio
BAIDUPAN_WORK_DIR=./backup
BYPY_BIN=bypy
BAIDUPCS_BIN=BaiduPCS-Go
BAIDUPCS_MAX_PARALLEL=16
